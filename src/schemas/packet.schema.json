{
  "$id": "https://3notch.dev/schemas/packet.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/recordMeta" },
    {
      "if": { "properties": { "purpose": { "const": "handoff" } }, "required": ["purpose"] },
      "then": {
        "properties": {
          "recipient": {
            "anyOf": [
              {
                "type": "object",
                "properties": { "targetAgent": { "type": "string", "minLength": 1 } },
                "required": ["targetAgent"]
              },
              {
                "type": "object",
                "properties": { "targetPerson": { "type": "string", "minLength": 1 } },
                "required": ["targetPerson"]
              },
              {
                "type": "object",
                "properties": { "targetRepo": { "type": "string", "minLength": 1 } },
                "required": ["targetRepo"]
              }
            ]
          }
        }
      }
    },
    {
      "if": { "properties": { "purpose": { "const": "seed" } }, "required": ["purpose"] },
      "then": {
        "properties": {
          "sensitivity": { "const": "private" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "replyTo": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/recordId" }
        },
        "required": ["replyTo"]
      },
      "then": {
        "required": ["replyType"],
        "properties": {
          "replyType": { "enum": ["question", "clarification", "counter-decision", "objection", "confirmation"] },
          "status": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/replyStatus" }
        }
      },
      "else": {
        "not": {
          "anyOf": [
            { "required": ["replyType"] },
            {
              "properties": {
                "status": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/replyStatus" }
              },
              "required": ["status"]
            }
          ]
        }
      }
    }
  ],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "schemaVersion",
    "recordType",
    "status",
    "title",
    "purpose",
    "sensitivity",
    "transferStatus",
    "origin",
    "recipient",
    "summary",
    "includedRecords",
    "includedSourceLinks",
    "createdAt",
    "createdBy",
    "sourceTool",
    "tags",
    "sourceLinks",
    "reviewStatus"
  ],
  "properties": {
    "id": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/recordId" },
    "schemaVersion": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/schemaVersion" },
    "recordType": { "const": "packet" },
    "status": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/packetStatus" },
    "title": { "type": "string", "minLength": 1 },
    "purpose": { "enum": ["handoff", "seed"] },
    "sensitivity": { "enum": ["project", "private"] },
    "transferStatus": { "enum": ["draft", "outbox", "imported", "archived"] },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectName", "storePath"],
      "properties": {
        "projectName": { "type": "string", "minLength": 1 },
        "storePath": { "type": "string", "minLength": 1 },
        "repoRoot": { "type": "string", "minLength": 1 },
        "repoRemote": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 }
      }
    },
    "recipient": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "targetAgent": { "type": "string", "minLength": 1 },
        "targetPerson": { "type": "string", "minLength": 1 },
        "targetRepo": { "type": "string", "minLength": 1 },
        "targetStore": { "type": "string", "minLength": 1 }
      }
    },
    "summary": { "type": "string", "minLength": 1 },
    "nextSteps": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/artifactEntry" }
    },
    "supersedes": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/recordId" },
    "replyTo": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/recordId" },
    "replyType": { "enum": ["question", "clarification", "counter-decision", "objection", "confirmation"] },
    "privateContextSummary": { "type": "string", "minLength": 1 },
    "includedRecords": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "recordType", "title", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "recordType": { "enum": ["project_brief", "brief"] },
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },
    "includedSourceLinks": {
      "type": "array",
      "items": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/sourceLink" }
    },
    "importNotes": { "type": "string", "minLength": 1 },
    "importedFrom": { "type": "string", "minLength": 1 },
    "importedAt": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/timestamp" },
    "createdAt": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/timestamp" },
    "updatedAt": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/timestamp" },
    "createdBy": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/actor" },
    "sourceTool": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/sourceTool" },
    "tags": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/tags" },
    "sourceLinks": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/sourceLinks" },
    "reviewStatus": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/reviewStatus" }
  }
}
