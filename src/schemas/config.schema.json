{
  "$id": "https://3notch.dev/schemas/config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "project", "store", "privacy", "defaults"],
  "properties": {
    "schemaVersion": { "$ref": "https://3notch.dev/schemas/shared.schema.json#/$defs/schemaVersion" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "defaultBranch": { "type": "string", "minLength": 1 }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "recordFormat", "index"],
      "properties": {
        "path": { "const": ".notch" },
        "recordFormat": { "const": "markdown-yaml" },
        "index": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "engine"],
          "properties": {
            "enabled": { "type": "boolean" },
            "engine": { "const": "file-scan" }
          }
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["telemetry", "redactPatterns", "secretScan", "highEntropySecretScan"],
      "properties": {
        "telemetry": { "const": false },
        "redactPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
              "kind": { "const": "regex" },
              "value": { "type": "string", "minLength": 1 },
              "flags": { "type": "string" }
            }
          }
        },
        "secretScan": { "type": "boolean" },
        "highEntropySecretScan": { "type": "boolean" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowedMcpWriteTools"],
      "properties": {
        "allowedMcpWriteTools": {
          "type": "array",
          "items": {
            "enum": [
              "create_brief",
              "create_packet",
              "import_packet",
              "create_mark",
              "create_reply",
              "create_seed_packet",
              "import_seed_packet"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxArtifactBytes": { "type": "integer", "minimum": 1 },
        "maxPacketBytes": { "type": "integer", "minimum": 1 },
        "scanTextExtensions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "continuation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "sensitivity", "semanticTriggers", "claudeCode"],
      "properties": {
        "mode": { "enum": ["off", "script", "prompt", "auto"] },
        "sensitivity": { "enum": ["project", "private"] },
        "streamOverride": { "type": "string", "minLength": 1 },
        "semanticTriggers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "claudeCode": {
          "type": "object",
          "additionalProperties": false,
          "required": ["events"],
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "enum": [
                  "SessionStart",
                  "TaskCreated",
                  "TaskCompleted",
                  "PostCompact",
                  "StopFailure:rate_limit",
                  "Stop"
                ]
              },
              "uniqueItems": true
            }
          }
        }
      }
    }
  }
}
