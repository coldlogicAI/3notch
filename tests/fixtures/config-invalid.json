{
  "schemaVersion": "1.0.0",
  "project": {
    "name": "fixture-app",
    "root": "/tmp/fixture-app"
  },
  "store": {
    "path": ".notch",
    "recordFormat": "markdown-yaml",
    "index": {
      "enabled": true,
      "engine": "sqlite"
    }
  },
  "privacy": {
    "telemetry": true,
    "redactPatterns": [],
    "secretScan": true,
    "highEntropySecretScan": true
  },
  "defaults": {
    "allowedMcpWriteTools": ["create_brief"]
  }
}
